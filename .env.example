# Copy this file to .env and fill in your real key. Never commit .env.
# --- LLM (OpenAI-compatible; Groq by default) ---
LLM_API_KEY=your_groq_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_MODEL_FALLBACK=llama-3.1-8b-instant

# --- Qdrant ---
#QDRANT_URL defaults to localhost & is overridden in Compose
#QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=docsrag

# --- Embeddings (local, fastembed) ---
EMBED_MODEL=BAAI/bge-small-en-v1.5
